<UserControl x:Class="Hearthstone_Deck_Tracker.Controls.Overlay.Constructed.Mulligan.V2.LinearGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Hearthstone_Deck_Tracker.Controls.Overlay.Constructed.Mulligan.V2"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
             lex:LocalizeDictionary.DesignCulture="en"
             lex:ResxLocalizationProvider.DefaultAssembly="HearthstoneDeckTracker"
             lex:ResxLocalizationProvider.DefaultDictionary="Strings"
             mc:Ignorable="d"
             d:DesignHeight="50" d:DesignWidth="212"
             d:DataContext="{d:DesignInstance local:ConstructedMulliganV2SingleCardHeaderViewModel}">
    <UserControl.Resources>
        <Storyboard x:Key="StoryboardFadeOut" Duration="0:0:1.5" FillBehavior="HoldEnd">
            <ColorAnimation
                Storyboard.TargetName="HandPositionChangeBrush"
                Storyboard.TargetProperty="Color"
                From="#80FFFFFF"
                To="#00FFFFFF"
                Duration="0:0:1.5"/>
        </Storyboard>
        <!-- <Storyboard x:Key="StoryboardFadeOut" Duration="0:0:1.5" FillBehavior="HoldEnd"> -->
        <!--     <DoubleAnimation Storyboard.TargetName="HandPositionChangeRect" Storyboard.TargetProperty="Opacity" From="0.5" To="0" Duration="0:0:1.5"/> -->
        <!-- </Storyboard> -->
    </UserControl.Resources>
    <Grid>
        <Border  CornerRadius="4" Height="20" VerticalAlignment="Center"
                 BorderBrush="Black"
                 BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="{Binding NegativeColor}" Offset="0"/>
                    <GradientStop Color="{Binding NeutralColor}" Offset="0.5"/>
                    <GradientStop Color="{Binding PositiveColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6"
                                  ShadowDepth="2"
                                  Direction="270"
                                  Color="Black"/>
            </Border.Effect>

            <Grid Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{lex:Loc MulliganGV2_Replace}"
                           FontWeight="Bold"
                           FontSize="12"
                           Margin="0 0 0 2"
                           VerticalAlignment="Center"
                           Foreground="Black"/>

                <TextBlock Grid.Column="2"
                           Text="{lex:Loc MulliganGV2_Keep}"
                           FontWeight="Bold"
                           FontSize="12"
                           Margin="0 0 0 2"
                           VerticalAlignment="Center"
                           Foreground="Black"/>
            </Grid>
        </Border>

        <Canvas Height="40"
            VerticalAlignment="Center"
            IsHitTestVisible="False">

            <Rectangle Height="18.5" Width="{Binding BandsWidth}"
                       Canvas.Left="{Binding LeftBand}"
                       Canvas.Top="11"
                       Fill="#66D3D3D3"
            >
            </Rectangle>

            <Canvas Visibility="{Binding CurrentHandPosition,
                                         Converter={StaticResource NullableToVisibility}}">

                <Polygon Points="0,0 10,0 5,8"
                         Fill="White"
                         Stroke="Black"
                         StrokeThickness="1"
                         Margin="-5 0 0 0"
                         Canvas.Left="{Binding CurrentHandPosition}"
                         Canvas.Top="6"/>
                <Line
                    X1="{Binding CurrentHandPosition}"
                    X2="{Binding CurrentHandPosition}"
                    Y1="8"
                    Y2="30"
                    Stroke="White"
                    StrokeThickness="2"
                />
                <Rectangle x:Name="HandPositionChangeRect"
                           Height="20"
                           Width="{Binding HandPositionChangeWidth}"
                           Canvas.Left="{Binding HandPositionChangeLeft}"
                           Canvas.Top="10"
                           SizeChanged="OnSizeChanged">

                    <Rectangle.Fill>
                        <SolidColorBrush x:Name="HandPositionChangeBrush"
                                         Color="#00FFFFFF"/>
                    </Rectangle.Fill>
                </Rectangle>
            </Canvas>
        </Canvas>
    </Grid>
</UserControl>
