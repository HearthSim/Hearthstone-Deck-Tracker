<UserControl x:Class="Hearthstone_Deck_Tracker.Controls.Overlay.Constructed.Mulligan.V2.ConstructedMulliganV2SingleCardStats"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Hearthstone_Deck_Tracker.Controls.Overlay.Constructed.Mulligan.V2"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <DockPanel Width="272">
        <Grid DockPanel.Dock="Top">
            <local:ConstructedMulliganV2SingleCardHeader DataContext="{Binding CardHeaderVM}" VerticalAlignment="Top"/>
        </Grid>

        <!-- Card Container -->
        <Grid Background="#00ff00ff" Margin="0 0 0 60" />
    </DockPanel>
</UserControl>

