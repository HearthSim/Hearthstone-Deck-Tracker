<UserControl x:Class="Hearthstone_Deck_Tracker.Controls.Overlay.Constructed.Mulligan.ConstructedMulliganPreLobbyWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Hearthstone_Deck_Tracker.Controls.Overlay.Constructed.Mulligan"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
             xmlns:commands="clr-namespace:Hearthstone_Deck_Tracker.Commands"
             xmlns:ext="clr-namespace:Hearthstone_Deck_Tracker.Utility.Extensions"
             lex:LocalizeDictionary.DesignCulture="en"
             lex:ResxLocalizationProvider.DefaultAssembly="HearthstoneDeckTracker"
             lex:ResxLocalizationProvider.DefaultDictionary="Strings"
             Width="1380" Height="1000"
             mc:Ignorable="d">
    <d:UserControl.DataContext>
        <local:ConstructedMulliganPreLobbyWidgetViewModel UserState="Subscribed" Username="molino">
        </local:ConstructedMulliganPreLobbyWidgetViewModel>
    </d:UserControl.DataContext>
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../OverlayResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBlock">
                <Style.Setters>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style.Setters>
            </Style>

            <Style TargetType="ToolTip" BasedOn="{StaticResource ArenaTooltipStyle}"/>
        </ResourceDictionary>
    </UserControl.Resources>


    <Grid Visibility="{Binding Visibility}">

        <!-- Interactive Panel -->
        <Border Name="MulliganPanel" MinWidth="{Binding PanelMinWidth}" Background="{StaticResource Tier7Black}"
                BorderBrush="{StaticResource HSReplayNetBlue}" BorderThickness="1" CornerRadius="0" HorizontalAlignment="Left" VerticalAlignment="Top"
                ext:OverlayExtensions.IsOverlayHitTestVisible="True">
            <StackPanel>
                <!-- Header -->
                <Border Background="{StaticResource HSReplayNetBlue}" Padding="8 5" Margin="-1 -1 -1 0" CornerRadius="4">
                    <DockPanel>
                        <Image
                            Height="12" Width="19"
                            Source="{Binding HSReplayIcon}"
                            RenderOptions.BitmapScalingMode="Fant"
                        />
                        <Border DockPanel.Dock="Right" Padding="4 3" Margin="0 -3 -6 -3" CornerRadius="3"
                                Cursor="Hand" MouseUp="Chevron_MouseUp">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="#22FFFFFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Rectangle Height="8" Width="16">
                                <Rectangle.Fill>
                                    <VisualBrush Visual="{Binding ChevronIcon, FallbackValue={StaticResource chevron_up}}" />
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                        <Border DockPanel.Dock="Right" Visibility="{Binding ShowOnboardingButton,Converter={StaticResource BoolToVisibility}}"
                                Padding="4 3"
                                Margin="0 -3 2 -3"
                                CornerRadius="3"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="#22FFFFFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <!-- Click handler -->
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding ToggleOnboardingCommand}" />
                            </Border.InputBindings>

                            <Rectangle Height="12" Width="10">
                                <Rectangle.Fill>
                                    <VisualBrush Visual="{StaticResource appbar_question}" />
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                        <Border DockPanel.Dock="Right" Padding="4 3" Margin="0 -3 2 -3" CornerRadius="3" Cursor="Hand"
                                Visibility="{Binding IsMouseOver, ElementName=MulliganPanel, Converter={StaticResource BoolToVisibility}, ConverterParameter=Hidden}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="#22FFFFFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="commands:GlobalCommands.ShowSettings" CommandParameter="Mulligan" />
                            </Border.InputBindings>
                            <Rectangle Height="14" Width="14">
                                <Rectangle.Fill>
                                    <VisualBrush Visual="{StaticResource appbar_settings}" />
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                        <TextBlock Text="{lex:Loc ConstructedPreLobby_InteractivePanel_Header}" Foreground="White" Margin="12 0" VerticalAlignment="Center" TextAlignment="Left" />
                    </DockPanel>
                </Border>
                <StackPanel Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBoolToVisibility}}">
                    <!-- Onboarding Notification-->
                    <Canvas Height="5" Visibility="{Binding ShowOnboardingNotification, Converter={StaticResource BoolToVisibility}}">
                        <Border Width="227" Canvas.Right="-250" Canvas.Top="-40" BorderBrush="#F21D3657" BorderThickness="1"
                                CornerRadius="4" Padding="20" Visibility="Visible"
                                ext:OverlayExtensions.IsOverlayHitTestVisible="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F21D3657" Offset="0"/>
                                                <GradientStop Color="#F2152B47" Offset="0.5"/>
                                                <GradientStop Color="#F21D3657" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <Grid>
                                            <!-- Close Button -->
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="18" Height="18"
                                                    Margin="0 -12 -12 0"
                                                    CornerRadius="3"
                                                    Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                                                <Setter Property="Background" Value="#22FFFFFF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseOnboaringNotificationCommand}" />
                                                </Border.InputBindings>
                                                <TextBlock Text="✕" Foreground="White" FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Tooltip Content -->
                                            <StackPanel Margin="0 0 0 0">
                                                <TextBlock Text="{lex:Loc ConstructedPreLobby_OnboardingNotification_Title}" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0 0 0 12"/>
                                                <TextBlock TextWrapping="Wrap" MaxWidth="200" Foreground="White" FontSize="12" Text="{lex:Loc ConstructedPreLobby_OnboardingNotification_Description}" />
                                                <TextBlock TextWrapping="Wrap" MaxWidth="200" Foreground="White" TextDecorations="Underline" Cursor="Hand" FontSize="12" Text="{lex:Loc ConstructedPreLobby_OnboardingNotification_LearnMore}" >
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding Gesture="LeftClick"
                                                                      Command="{Binding OnboardingLearnMoreCommand}" />
                                                    </TextBlock.InputBindings>
                                                </TextBlock>

                                            </StackPanel>
                                        </Grid>
                                    </Border>

                        <Polygon Canvas.Right="-23" Canvas.Top="6" Fill="{StaticResource HSReplayNetBlue}" Points="24,0 5,12 24,24"/>
                    </Canvas>
                    <!-- Loading -->
                    <StackPanel Margin="16" Visibility="{Binding UserState, Converter={StaticResource EnumToVisibility}, ConverterParameter={x:Static local:UserState.Loading}}">
                        <TextBlock Text="{lex:Loc BattlegroundsPreLobby_InteractivePanel_Loading}" />
                    </StackPanel>

                    <!-- UnknownPlayer -->
                    <StackPanel Width="182" Margin="16" Visibility="{Binding UserState, Converter={StaticResource EnumToVisibility}, ConverterParameter={x:Static local:UserState.UnknownPlayer}}">
                        <StackPanel Name="HoverTrigger" >
                            <Image Source="{StaticResource Tier7PreLobbySmall}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="Fant" HorizontalAlignment="Center" Margin="0 -8 0 0" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Background="{StaticResource Tier7Black}">
                                <TextBlock Text="{lex:Loc ConstructedPreLobby_InteractivePanel_Anonymous_Hover}" Foreground="#07618B"/>
                                <Rectangle Fill="#07618B" Width="17" Height="17" Margin="4 0 0 0">
                                    <Rectangle.OpacityMask>
                                        <VisualBrush Visual="{DynamicResource appbar_magnify}" />
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{lex:Loc ConstructedPreLobby_InteractivePanel_Anonymous_Hover_Details}" Margin="0 8 0 0" />
                    </StackPanel>

                    <!-- ValidPlayer -->
                    <StackPanel Width="230" Margin="16" Visibility="{Binding UserState, Converter={StaticResource EnumToVisibility}, ConverterParameter={x:Static local:UserState.ValidPlayer}}">
                        <TextBlock Foreground="{StaticResource HSReplayNetPremiumGold}" FontWeight="SemiBold">
                        <Run Text="{lex:Loc BattlegroundsPreLobby_Welcome}"/>
                        <Run Text="{Binding Username}"/>!
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 8 0 0">
                            <TextBlock FontWeight="SemiBold" Margin="0 0 8 0">
                            <Run Text="{lex:Loc BattlegroundsPreLobby_TrialsRemaining}"/>
                            <Run Text="{Binding TrialUsesRemaining}"/>
                            </TextBlock>
                            <Border Width="18" Height="18" BorderBrush="White" Background="{StaticResource Tier7Black}" BorderThickness="1" CornerRadius="18"
                                ToolTipService.InitialShowDelay="0" ToolTip="{lex:Loc ConstructedPreLobby_TrialsRemaining_Tooltip}">
                                <TextBlock Text="i" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding ResetTimeVisibility}">
                            <TextBlock>
                            <Run Text="{lex:Loc BattlegroundsPreLobby_TrialsResetsIn}" />
                            <Bold><Run Text="{Binding TrialTimeRemaining}" /></Bold>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{lex:Loc ConstructedPreLobby_Join}" TextWrapping="Wrap" Margin="0 8 0 0" />
                        <Grid>
                            <Button Cursor="Hand" Height="25" Style="{StaticResource SubscribeButton}" Margin="0 8 0 0" Command="{Binding SubscribeNowCommand}">
                                <Button.Content>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="SUBSCRIBE NOW" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.ColumnSpan="2"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                                        <!-- Sale Tag -->
                                        <Grid HorizontalAlignment="Right" Grid.Column="1" Visibility="{Binding SaleTagVisibility}">
                                            <!-- Diagonal separator -->
                                            <Path Fill="#b94038" VerticalAlignment="Stretch" HorizontalAlignment="Left" Width="15">
                                                <Path.Data>
                                                    <PathGeometry>
                                                        <PathFigure StartPoint="0,0">
                                                            <LineSegment Point="15,0"/>
                                                            <LineSegment Point="15,25"/>
                                                            <LineSegment Point="0,25"/>
                                                            <LineSegment Point="10,0"/>
                                                        </PathFigure>
                                                    </PathGeometry>
                                                </Path.Data>
                                            </Path>

                                            <!-- Sale tag body -->
                                            <Border Background="#b94038"  Padding="8,0" Height="25" Margin="10 0 0 0">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" Direction="315" ShadowDepth="1" Opacity="0.3" BlurRadius="2"/>
                                                </Border.Effect>

                                                <TextBlock Text="{lex:Loc BattlegroundsPreLobby_SaleTag}" FontSize="12" FontWeight="Bold" Foreground="White"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Button.Content>
                            </Button>
                            <!-- Tooltip -->
                            <Canvas Height="25" Visibility="{Binding SaleTooltipVisibility}">
                                    <Border Width="227" Canvas.Right="-250" Canvas.Top="-40" BorderBrush="#F21D3657" BorderThickness="1"
                                            CornerRadius="4" Padding="20" Visibility="Visible"
                                            ext:OverlayExtensions.IsOverlayHitTestVisible="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F21D3657" Offset="0"/>
                                                <GradientStop Color="#F2152B47" Offset="0.5"/>
                                                <GradientStop Color="#F21D3657" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <Grid>
                                            <!-- Close Button -->
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="18" Height="18"
                                                    Margin="0 -12 -12 0"
                                                    CornerRadius="3"
                                                    Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                                                <Setter Property="Background" Value="#22FFFFFF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseSaleTooltipCommand}" />
                                                </Border.InputBindings>
                                                <TextBlock Text="✕" Foreground="White" FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Tooltip Content -->
                                            <StackPanel Margin="0 0 0 0">
                                                <TextBlock Text="{lex:Loc BattlegroundsPreLobby_SaleTooltip_Title}" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0 0 0 12"/>
                                                <TextBlock TextWrapping="Wrap" MaxWidth="200" Foreground="White" FontSize="12" Text="{Binding SaleDescription}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Polygon Canvas.Right="-23" Canvas.Top="6" Fill="{StaticResource HSReplayNetBlue}" Points="24,0 5,12 24,24"/>
                                </Canvas>
                        </Grid>
                        <!-- Subscribed? Sign In -->
                        <TextBlock Margin="0 8 1 0" Visibility="{Binding RefreshSubscriptionState, Converter={StaticResource EnumToVisibility}, ConverterParameter={x:Static local:RefreshSubscriptionState.SignIn}}">
                        <Run Text="{lex:Loc BattlegroundsPreLobby_AlreadySubscribed}"/>
                        <Hyperlink Command="commands:GlobalCommands.SignInCommand">
                            <Run Text="{lex:Loc BattlegroundsPreLobby_SignInToSubscription}"/>
                        </Hyperlink>
                        </TextBlock>

                        <!-- Subscribed? Refresh -->
                        <TextBlock Margin="0 8 0 0" Visibility="{Binding RefreshSubscriptionState, Converter={StaticResource EnumToVisibility}, ConverterParameter={x:Static local:RefreshSubscriptionState.Refresh}}">
                        <Run Text="{lex:Loc BattlegroundsPreLobby_AlreadySubscribed}"/>
                        <Hyperlink Command="{Binding RefreshAccountCommand}" IsEnabled="{Binding RefreshAccountEnabled}">
                            <Run Text="{lex:Loc BattlegroundsPreLobby_RefreshSubscription}"/>
                        </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- Subscribed -->
                    <StackPanel Width="230" Margin="16" Visibility="{Binding UserState, Converter={StaticResource EnumToVisibility}, ConverterParameter={x:Static local:UserState.Subscribed}}">
                        <TextBlock Text="{lex:Loc ConstructedPreLobby_Subscribed_Premium}" Foreground="{StaticResource HSReplayNetPremiumGold}" FontWeight="SemiBold"/>

                        <Button Style="{StaticResource Tier7ButtonStyle}" Content="{lex:Loc BattlegroundsPreLobby_Subscribed_MyStats}" Margin="0 16 0 0" Command="{Binding MyStatsCommand}"/>
                    </StackPanel>

                    <!-- Disabled -->
                    <DockPanel Width="182" Margin="16" Visibility="{Binding UserState, Converter={StaticResource EnumToVisibility}, ConverterParameter={x:Static local:UserState.Disabled}}">
                        <Rectangle Fill="{StaticResource HSReplayNetPremiumGold}" Width="17" Height="15" Margin="4 0 0 0" DockPanel.Dock="Right">
                            <Rectangle.OpacityMask>
                                <VisualBrush Visual="{DynamicResource appbar_warning}" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="{lex:Loc BattlegroundsPreLobby_Disabled}" TextWrapping="Wrap" />
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </Border>
        <!-- Onboarding Overlay -->
        <Grid Visibility="{Binding IsOnboardingVisible, Converter={StaticResource BoolToVisibility}}"
              ext:OverlayExtensions.IsOverlayHitTestVisible="True">

            <Border
                   Background="#141617"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   CornerRadius="4"
                   >

                <Grid>
                    <!-- Center Content -->
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="40">

                        <!-- 3 rows: top label, image row, spacing -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 3 columns: left label, image, right label -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- TOP BOX -->
                        <Border Grid.Row="0" Grid.Column="1"
                                Margin="10 0 0 12"
                                HorizontalAlignment="Center"
                                BorderBrush="#3A4246"
                                BorderThickness="1"
                                CornerRadius="4"
                                Width="220">

                            <StackPanel>
                                <Border Background="#2A3135" Padding="6" CornerRadius="4,4,0,0">
                                    <TextBlock Text="{lex:Loc MulliganGV2_OnboardingSynergy_Title}"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Center"/>
                                </Border>

                                <Border Background="#141617" Padding="8" CornerRadius="0,0,4,4">
                                    <TextBlock Text="{lex:Loc MulliganGV2_OnboardingSynergy_Description}"
                                               Foreground="White"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- LEFT BOX  -->
                        <Border Grid.Row="1" Grid.Column="0"
                                Margin="0 0 12 0"
                                VerticalAlignment="Top"
                                BorderBrush="#3A4246"
                                BorderThickness="1"
                                CornerRadius="4"
                                Width="220">

                            <StackPanel>
                                <Border Background="#2A3135" Padding="6" CornerRadius="4,4,0,0">
                                    <TextBlock Text="{lex:Loc MulliganGV2_OnboardingBar_Title}"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Center"/>
                                </Border>

                                <Border Background="#141617" Padding="8" CornerRadius="0,0,4,4">
                                    <TextBlock Text="{lex:Loc MulliganGV2_OnboardingBar_Description}"
                                               Foreground="White"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- IMAGE (centered anchor) -->
                        <Image Grid.Row="1" Grid.Column="1"
                               Source="/HearthstoneDeckTracker;component/Resources/Mulligan-GV2/mulligan-gv2-elements.png"
                               Width="250"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"/>

                        <!-- RIGHT BOX -->
                        <Border Grid.Row="1" Grid.Column="2"
                                Margin="12 35 0 0"
                                VerticalAlignment="Top"
                                BorderBrush="#3A4246"
                                BorderThickness="1"
                                CornerRadius="4"
                                Width="220">

                            <StackPanel>
                                <Border Background="#2A3135" Padding="6" CornerRadius="4,4,0,0">
                                    <TextBlock Text="{lex:Loc MulliganGV2_OnboardingShadowBar_Title}"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Center"/>
                                </Border>

                                <Border Background="#141617" Padding="8" CornerRadius="0,0,4,4">
                                    <TextBlock Text="{lex:Loc MulliganGV2_OnboardingShadowBar_Description}"
                                               Foreground="White"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <!-- Close Button -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0 20 20 0"
                            Width="30"
                            Height="30"
                            CornerRadius="15"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ToggleOnboardingCommand}" />
                        </Border.InputBindings>
                        <TextBlock Text="✕"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

